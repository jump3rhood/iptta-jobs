NODE_ENV=production

MONGODB_URI=mongodb+srv://...
RESEND_API_KEY=re_...
# After verifying your domain in Resend, set this to your domain sender.
# Until then, leave it unset — emails will send from onboarding@resend.dev (Resend test sender).
EMAIL_FROM=IPTTA Jobs <noreply@iptta.com>
ADMIN_PASSWORD=your_password
JWT_SECRET=your_secret_32_chars_minimum
ADMIN_EMAIL=your@email.com

# Production URLs
CLIENT_URL=https://jobs.iptta.com
API_URL=https://api.jobs.iptta.com
PORT=5000

# --- For local dev, use these instead (in your .env, not this file) ---
# CLIENT_URL=http://localhost:5173
# API_URL=http://localhost:5000
